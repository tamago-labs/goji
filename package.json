{
  "name": "@tamago-labs/goji",
  "version": "0.1.2",
  "description": "Visual payment flows for DAOs and teams. P2P collaborative canvas with Circle Wallets integration.",
  "main": "src/index.js",
  "bin": {
    "goji": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js --port 3001",
    "start:guest": "node src/index.js --port 3002 --guest",
    "build:specs": "node schema.js",
    "clean:storage": "node scripts/clean-storage.js",
    "lint": "prettier . --check && lunte",
    "format": "prettier . --write"
  },
  "keywords": [
    "dao",
    "payroll",
    "p2p",
    "hyperswarm",
    "circle",
    "wallet",
    "usdc",
    "collaboration",
    "canvas"
  ],
  "dependencies": {
    "autobase": "^7.28.1",
    "b4a": "^1.8.1",
    "blind-pairing": "^2.3.1",
    "corestore": "^7.9.2",
    "debounceify": "^1.1.0",
    "express": "^4.18.2",
    "hypercore-crypto": "^3.7.0",
    "hyperdb": "^6.7.0",
    "hyperdispatch": "^1.6.0",
    "hyperschema": "^1.21.0",
    "hyperswarm": "^4.17.0",
    "keet-identity-key": "^3.2.0",
    "ready-resource": "^1.2.0",
    "ws": "^8.18.0",
    "z32": "^1.1.0"
  },
  "devDependencies": {
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tamago-labs/goji.git",
    "directory": "frontend"
  },
  "homepage": "https://github.com/tamago-labs/goji",
  "bugs": {
    "url": "https://github.com/tamago-labs/goji/issues"
  },
  "author": "Tamago Labs",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "spec/",
    "scripts/",
    "schema.js",
    "README.md"
  ]
}
